{
  "info": {
    "name": "Sumativa Cloud Native - Semana 6 EC2",
    "description": "Coleccion ordenada para probar el flujo completo desplegado en EC2: EFS, S3, descarga con permiso, errores esperados y eliminacion.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('baseUrl')) pm.environment.set('baseUrl', 'https://bab3x5yn3m.execute-api.us-east-1.amazonaws.com');",
          "if (!pm.environment.get('fecha')) pm.environment.set('fecha', '202606');",
          "if (!pm.environment.get('transportista')) pm.environment.set('transportista', 'transportistaX');",
          "if (!pm.environment.get('credencialDescarga')) pm.environment.set('credencialDescarga', 'clave123');",
          "if (!pm.environment.get('credencialIncorrecta')) pm.environment.set('credencialIncorrecta', 'clave-incorrecta');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 - Preparacion",
      "item": [
        {
          "name": "00.1 API responde en EC2",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista={{transportista}}&fecha={{fecha}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "{{transportista}}"
                },
                {
                  "key": "fecha",
                  "value": "{{fecha}}"
                }
              ]
            },
            "description": "Primera prueba. Confirma que el backend desplegado responde y que la fecha usa formato YYYYMM."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Respuesta tipo lista', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Flujo completo de guia",
      "item": [
        {
          "name": "01.1 Crear guia en EFS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ]
            },
            "description": "Crea la guia y guarda idGuia para las siguientes solicitudes. En EC2 debe aparecer bajo /mnt/efs/{{fecha}}/{{transportista}}/.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transportista\": \"{{transportista}}\",\n  \"credencialDescarga\": \"{{credencialDescarga}}\",\n  \"fecha\": \"{{fecha}}\",\n  \"contenido\": \"Pedido 1001, destino Santiago, bultos 3. Evidencia de creacion temporal en EFS.\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Guia creada', function () { pm.expect(json.estado).to.eql('CREADA'); });",
                  "pm.test('Guarda idGuia', function () { pm.expect(json.idGuia).to.exist; pm.environment.set('idGuia', json.idGuia); });",
                  "pm.test('Archivo temporal registrado', function () { pm.expect(json.efsPath).to.include(pm.environment.get('fecha')); pm.expect(json.tamanioBytes).to.be.above(0); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.2 Subir guia a S3",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}/s3",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}",
                "s3"
              ]
            },
            "description": "Sube la guia creada al bucket S3 configurado en APP_STORAGE_S3_BUCKET."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const expectedKey = pm.environment.get('fecha') + '/' + pm.environment.get('transportista') + '/guia' + pm.environment.get('idGuia') + '.pdf';",
                  "pm.test('Estado SUBIDA_S3', function () { pm.expect(json.estado).to.eql('SUBIDA_S3'); });",
                  "pm.test('S3 key esperada', function () { pm.expect(json.s3Key).to.eql(expectedKey); pm.environment.set('s3Key', json.s3Key); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.3 Descargar con clave incorrecta - debe dar 403",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}/descarga",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}",
                "descarga"
              ]
            },
            "description": "Evidencia de validacion de permisos: una credencial incorrecta no puede descargar.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credencialDescarga\": \"{{credencialIncorrecta}}\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', function () { pm.response.to.have.status(403); });",
                  "pm.test('Mensaje de rechazo', function () { pm.expect(pm.response.json().message).to.include('no autorizada'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.4 Descargar con clave correcta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}/descarga",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}",
                "descarga"
              ]
            },
            "description": "Usa Send and Download en Postman para guardar el PDF como evidencia.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credencialDescarga\": \"{{credencialDescarga}}\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Content-Type PDF', function () { pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf'); });",
                  "pm.test('Nombre de archivo', function () { pm.expect(pm.response.headers.get('Content-Disposition')).to.include('guia' + pm.environment.get('idGuia') + '.pdf'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.5 Actualizar guia",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}"
              ]
            },
            "description": "Actualiza contenido y vuelve a subir el mismo objeto a S3.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transportista\": \"{{transportista}}\",\n  \"credencialDescarga\": \"{{credencialDescarga}}\",\n  \"fecha\": \"{{fecha}}\",\n  \"contenido\": \"Pedido 1001 actualizado, destino Valparaiso, bultos 4. Evidencia de actualizacion en EFS y S3.\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Estado ACTUALIZADA', function () { pm.expect(json.estado).to.eql('ACTUALIZADA'); });",
                  "pm.test('Mantiene s3Key', function () { pm.expect(json.s3Key).to.eql(pm.environment.get('s3Key')); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.6 Consultar por transportista y fecha",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista={{transportista}}&fecha={{fecha}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "{{transportista}}"
                },
                {
                  "key": "fecha",
                  "value": "{{fecha}}"
                }
              ]
            },
            "description": "Consulta el historial filtrado por transportista y periodo YYYYMM."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Guia aparece en historial', function () { const item = json.find(g => String(g.idGuia) === String(pm.environment.get('idGuia'))); pm.expect(item).to.exist; pm.expect(item.estado).to.eql('ACTUALIZADA'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.7 Eliminar guia",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}"
              ]
            },
            "description": "Elimina el objeto en S3 y marca la guia como ELIMINADA."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Estado ELIMINADA', function () { pm.expect(json.estado).to.eql('ELIMINADA'); pm.expect(json.s3Key).to.eql(null); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.8 Confirmar que ya no aparece en consulta activa",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista={{transportista}}&fecha={{fecha}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "{{transportista}}"
                },
                {
                  "key": "fecha",
                  "value": "{{fecha}}"
                }
              ]
            },
            "description": "La consulta activa excluye guias eliminadas, por eso el id eliminado ya no debe aparecer."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Guia eliminada no aparece', function () { const item = json.find(g => String(g.idGuia) === String(pm.environment.get('idGuia'))); pm.expect(item).to.not.exist; });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Validaciones de entrada",
      "item": [
        {
          "name": "02.1 Crear guia con fecha invalida - debe dar 400",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ]
            },
            "description": "El backend exige fecha en formato YYYYMM.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transportista\": \"{{transportista}}\",\n  \"credencialDescarga\": \"{{credencialDescarga}}\",\n  \"fecha\": \"2026-06\",\n  \"contenido\": \"Solicitud con fecha invalida.\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Mensaje menciona YYYYMM', function () { pm.expect(pm.response.json().message).to.include('YYYYMM'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "02.2 Consultar con fecha invalida - debe fallar",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista={{transportista}}&fecha=2026-06",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "{{transportista}}"
                },
                {
                  "key": "fecha",
                  "value": "2026-06"
                }
              ]
            },
            "description": "Caso negativo para evidenciar que una fecha mal escrita no pasa como consulta valida."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status de error', function () { pm.expect(pm.response.code).to.be.oneOf([400, 500]); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://bab3x5yn3m.execute-api.us-east-1.amazonaws.com"
    },
    {
      "key": "transportista",
      "value": "transportistaX"
    },
    {
      "key": "credencialDescarga",
      "value": "clave123"
    },
    {
      "key": "credencialIncorrecta",
      "value": "clave-incorrecta"
    },
    {
      "key": "fecha",
      "value": "202606"
    },
    {
      "key": "idGuia",
      "value": ""
    },
    {
      "key": "s3Key",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": "PEGAR_TOKEN_AZURE_B2C"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  }
}
