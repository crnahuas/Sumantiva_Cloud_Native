{
  "info": {
    "name": "Sumativa Cloud Native - Semana 6 API Gateway",
    "description": "Coleccion ordenada para probar Semana 6 por API Gateway: roles Azure B2C, EFS, S3, descarga con permiso, errores esperados y eliminacion.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const defaults = {",
          "  baseUrl: 'https://bab3x5yn3m.execute-api.us-east-1.amazonaws.com',",
          "  fecha: '202606',",
          "  transportista: 'transportistaX',",
          "  credencialDescarga: 'clave123',",
          "  credencialIncorrecta: 'clave-incorrecta'",
          "};",
          "Object.keys(defaults).forEach(function (key) {",
          "  const value = pm.environment.get(key);",
          "  if (!value || String(value).trim() === '') {",
          "    pm.environment.set(key, defaults[key]);",
          "  }",
          "  pm.collectionVariables.set(key, pm.environment.get(key) || defaults[key]);",
          "});",
          "['gestorToken', 'descargaToken'].forEach(function (key) {",
          "  const value = pm.environment.get(key) || pm.collectionVariables.get(key);",
          "  if (value) { pm.collectionVariables.set(key, value); }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 - Preparacion",
      "item": [
        {
          "name": "00.1 API responde por API Gateway",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista=transportistaX&fecha=202606",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "transportistaX"
                },
                {
                  "key": "fecha",
                  "value": "202606"
                }
              ]
            },
            "description": "Primera prueba. Confirma que el backend desplegado responde y que la fecha usa formato YYYYMM."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Respuesta tipo lista', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "01 - Flujo completo de guia",
      "item": [
        {
          "name": "01.1 Crear guia en EFS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ]
            },
            "description": "Crea la guia y guarda idGuia para las siguientes solicitudes. En la EC2 debe aparecer bajo /mnt/efs/202606/transportistaX/.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transportista\": \"transportistaX\",\n  \"credencialDescarga\": \"clave123\",\n  \"fecha\": \"202606\",\n  \"contenido\": \"Pedido 1001, destino Santiago, bultos 3. Evidencia de creacion temporal en EFS.\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Guia creada', function () { pm.expect(json.estado).to.eql('CREADA'); });",
                  "pm.test('Guarda idGuia', function () { pm.expect(json.idGuia).to.exist; pm.environment.set('idGuia', json.idGuia); });",
                  "pm.test('Archivo temporal registrado', function () { pm.expect(json.efsPath).to.include('202606'); pm.expect(json.tamanioBytes).to.be.above(0); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        },
        {
          "name": "01.2 Subir guia a S3",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}/s3",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}",
                "s3"
              ]
            },
            "description": "Sube la guia creada al bucket S3 configurado en APP_STORAGE_S3_BUCKET."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const expectedKey = '202606' + '/' + 'transportistaX' + '/guia' + pm.environment.get('idGuia') + '.pdf';",
                  "pm.test('Estado SUBIDA_S3', function () { pm.expect(json.estado).to.eql('SUBIDA_S3'); });",
                  "pm.test('S3 key esperada', function () { pm.expect(json.s3Key).to.eql(expectedKey); pm.environment.set('s3Key', json.s3Key); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        },
        {
          "name": "01.3 Descargar con clave incorrecta - debe dar 403",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}/descarga",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}",
                "descarga"
              ]
            },
            "description": "Evidencia de validacion de permisos: una credencial incorrecta no puede descargar.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credencialDescarga\": \"clave-incorrecta\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', function () { pm.response.to.have.status(403); });",
                  "pm.test('Mensaje de rechazo', function () { pm.expect(pm.response.json().message).to.include('no autorizada'); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{descargaToken}}",
                "type": "string"
              }
            ]
          }
        },
        {
          "name": "01.4 Descargar con clave correcta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}/descarga",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}",
                "descarga"
              ]
            },
            "description": "Usa Send and Download en Postman para guardar el PDF como evidencia.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credencialDescarga\": \"clave123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Content-Type PDF', function () { pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf'); });",
                  "pm.test('Nombre de archivo', function () { pm.expect(pm.response.headers.get('Content-Disposition')).to.include('guia' + pm.environment.get('idGuia') + '.pdf'); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{descargaToken}}",
                "type": "string"
              }
            ]
          }
        },
        {
          "name": "01.5 Actualizar guia",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}"
              ]
            },
            "description": "Actualiza contenido y vuelve a subir el mismo objeto a S3.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transportista\": \"transportistaX\",\n  \"credencialDescarga\": \"clave123\",\n  \"fecha\": \"202606\",\n  \"contenido\": \"Pedido 1001 actualizado, destino Valparaiso, bultos 4. Evidencia de actualizacion en EFS y S3.\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Estado ACTUALIZADA', function () { pm.expect(json.estado).to.eql('ACTUALIZADA'); });",
                  "pm.test('Mantiene s3Key', function () { pm.expect(json.s3Key).to.eql(pm.environment.get('s3Key')); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        },
        {
          "name": "01.6 Consultar por transportista y fecha",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista=transportistaX&fecha=202606",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "transportistaX"
                },
                {
                  "key": "fecha",
                  "value": "202606"
                }
              ]
            },
            "description": "Consulta el historial filtrado por transportista y periodo YYYYMM."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Guia aparece en historial', function () { const item = json.find(g => String(g.idGuia) === String(pm.environment.get('idGuia'))); pm.expect(item).to.exist; pm.expect(item.estado).to.eql('ACTUALIZADA'); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        },
        {
          "name": "01.7 Eliminar guia",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias/{{idGuia}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "{{idGuia}}"
              ]
            },
            "description": "Elimina el objeto en S3 y marca la guia como ELIMINADA."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Estado ELIMINADA', function () { pm.expect(json.estado).to.eql('ELIMINADA'); pm.expect(json.s3Key).to.eql(null); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        },
        {
          "name": "01.8 Confirmar que ya no aparece en consulta activa",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista=transportistaX&fecha=202606",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "transportistaX"
                },
                {
                  "key": "fecha",
                  "value": "202606"
                }
              ]
            },
            "description": "La consulta activa excluye guias eliminadas, por eso el id eliminado ya no debe aparecer."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Guia eliminada no aparece', function () { const item = json.find(g => String(g.idGuia) === String(pm.environment.get('idGuia'))); pm.expect(item).to.not.exist; });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Validaciones de entrada",
      "item": [
        {
          "name": "02.1 Crear guia con fecha invalida - debe dar 400",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ]
            },
            "description": "El backend exige fecha en formato YYYYMM.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transportista\": \"transportistaX\",\n  \"credencialDescarga\": \"clave123\",\n  \"fecha\": \"2026-06\",\n  \"contenido\": \"Solicitud con fecha invalida.\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Mensaje menciona YYYYMM', function () { pm.expect(pm.response.json().message).to.include('YYYYMM'); });"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        },
        {
          "name": "02.2 Consultar con fecha invalida - rechazo esperado",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista=transportistaX&fecha=2026-06",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "transportistaX"
                },
                {
                  "key": "fecha",
                  "value": "2026-06"
                }
              ]
            },
            "description": "Caso negativo: se envia fecha=2026-06 para demostrar que el backend no acepta consultas fuera del formato YYYYMM. La respuesta esperada es un error, no una lista 200."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('La consulta invalida no devuelve 200', function () {",
                  "  pm.expect(pm.response.code).to.not.eql(200);",
                  "});",
                  "pm.test('La respuesta es error de validacion o error controlado por el framework', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 422, 500]);",
                  "});"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Validacion de roles Azure AD B2C",
      "item": [
        {
          "name": "03.1 DESCARGA_GUIAS no puede crear guias - debe dar 403",
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{descargaToken}}",
                "type": "string"
              }
            ]
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ]
            },
            "description": "Valida que el rol DESCARGA_GUIAS queda limitado al endpoint de descarga y no puede administrar guias.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transportista\": \"transportistaX\",\n  \"credencialDescarga\": \"clave123\",\n  \"fecha\": \"202606\",\n  \"contenido\": \"Intento de creacion con rol de descarga.\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', function () { pm.response.to.have.status(403); });"
                ]
              }
            }
          ]
        },
        {
          "name": "03.2 GESTOR_GUIAS no puede descargar - debe dar 403",
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{gestorToken}}",
                "type": "string"
              }
            ]
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/guias/1/descarga",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias",
                "1",
                "descarga"
              ]
            },
            "description": "Valida que el endpoint de descarga queda reservado para DESCARGA_GUIAS. Se usa id 1 fijo porque la autorizacion debe rechazar con 403 antes de consultar si la guia existe.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credencialDescarga\": \"clave123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', function () { pm.response.to.have.status(403); });"
                ]
              }
            }
          ]
        },
        {
          "name": "03.3 Sin token no puede consultar - debe dar 401",
          "auth": {
            "type": "noauth"
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/guias?transportista=transportistaX&fecha=202606",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "guias"
              ],
              "query": [
                {
                  "key": "transportista",
                  "value": "transportistaX"
                },
                {
                  "key": "fecha",
                  "value": "202606"
                }
              ]
            },
            "description": "Valida que las llamadas sin token JWT se rechazan antes de llegar a la funcionalidad."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://bab3x5yn3m.execute-api.us-east-1.amazonaws.com"
    },
    {
      "key": "transportista",
      "value": "transportistaX"
    },
    {
      "key": "credencialDescarga",
      "value": "clave123"
    },
    {
      "key": "credencialIncorrecta",
      "value": "clave-incorrecta"
    },
    {
      "key": "fecha",
      "value": "202606"
    },
    {
      "key": "idGuia",
      "value": ""
    },
    {
      "key": "s3Key",
      "value": ""
    },
    {
      "key": "gestorToken",
      "value": "PEGAR_TOKEN_GESTOR_GUIAS"
    },
    {
      "key": "descargaToken",
      "value": "PEGAR_TOKEN_DESCARGA_GUIAS"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{gestorToken}}",
        "type": "string"
      }
    ]
  }
}
